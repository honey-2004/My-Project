<?php
/**
 * @var \Iovista\Blog\Block\Post\View $block
 */
$post = $block->getPost();
?>
<?php if ($post && $post->getId()): ?>
    <div class="blog-post-view">
        <div class="blog-post-back">
            <a href="<?= $block->escapeUrl($block->getBlogUrl()) ?>"><?= __('← Back to Blog') ?></a>
        </div>
        
        <h1><?= $block->escapeHtml($post->getTitle() ?: $post->getName()) ?></h1>
        
        <div class="blog-post-meta">
            <?php if ($post->getPostDate()): ?>
                <span class="post-date">
                    <?= __('Posted on: %1', $block->escapeHtml($post->getPostDate())) ?>
                </span>
            <?php endif; ?>
            
            <?php if ($post->getAuthor()): ?>
                <span class="post-author">
                    <?= __('By: %1', $block->escapeHtml($post->getAuthor())) ?>
                </span>
            <?php endif; ?>
        </div>
        
        <?php if ($post->getBannerImage()): ?>
            <div class="blog-post-image">
                <img src="<?= $block->escapeUrl($block->getImageUrl($post->getBannerImage())) ?>" 
                     alt="<?= $block->escapeHtmlAttr($post->getTitle() ?: $post->getName()) ?>" />
            </div>
        <?php endif; ?>
        
        <?php if ($post->getShortDescription()): ?>
            <div class="blog-post-short-description">
                <?= /* @noEscape */ $post->getShortDescription() ?>
            </div>
        <?php endif; ?>
        
        <?php if ($post->getLongDescription()): ?>
            <div class="blog-post-content">
                <?= /* @noEscape */ $post->getLongDescription() ?>
            </div>
        <?php endif; ?>
    </div>
<?php else: ?>
    <div class="message error">
        <p><?= __('Post not found.') ?></p>
        <a href="<?= $block->escapeUrl($block->getBlogUrl()) ?>"><?= __('Back to Blog') ?></a>
    </div>
<?php endif; ?>

